datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id String @id @default(cuid())

  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  role      UserRole @default(ADMIN)

  projects               ProjectMember[]
  calculations           Calculation[]
  assignedTasks          Task[]           @relation("TaskAssignee")
  createdTasks           Task[]           @relation("TaskCreatedBy")
  taskViews              TaskView[]       @relation("TaskViews")
  assignedRecurringTasks RecurringTask[]  @relation("RecurringTaskAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

// ============================================
// PROJECTS
// ============================================

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)

  members                  ProjectMember[]
  tasks                    Task[]
  recurringTasks           RecurringTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

model ProjectMember {
  id String @id @default(cuid())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

// ============================================
// TASKS
// ============================================

model Task {
  id          String       @id @default(cuid())
  name        String
  description String?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  attachments Attachment[]

  blockedByTasks Task[] @relation("TaskBlockedByTask")
  blockingTasks  Task[] @relation("TaskBlockedByTask")

  createdById String?
  createdBy   User?   @relation("TaskCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
}

model Attachment {
  id   String @id @default(cuid())
  name String
  url  String
  type String
  size Int

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING_ADMIN_REVIEW
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

// ============================================
// VIEWS (saved filters for tasks)
// ============================================

model TaskView {
  id   String @id @default(cuid())
  name String

  viewMode      String  @default("table")
  sortColumn    String?
  sortDirection String  @default("asc")

  statusFilters    String[]
  priorityFilters  String[]
  projectFilters   String[]
  assigneeFilters  String[]
  createdByFilters String[]

  userId String
  user   User   @relation("TaskViews", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}


// ============================================
// RECURRING TASKS
// ============================================

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model RecurringTask {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)

  frequency  RecurrenceFrequency
  dayOfWeek  Int?
  dayOfMonth Int?
  isActive   Boolean             @default(true)

  lastCreatedAt DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  assigneeId String?
  assignee   User?   @relation("RecurringTaskAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([isActive])
}

// ============================================
// CALCULATIONS
// ============================================

model Calculation {
  id          String   @id @default(cuid())
  name        String
  description String?
  flowData    Json?
  createdBy   User     @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// FORM SUBMISSIONS (generic)
// ============================================

model FormSubmission {
  id String @id @default(cuid())

  name    String
  email   String
  message String?  @db.Text
  fields  Json?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// ============================================
// INTEGRATION SETTINGS
// ============================================

model IntegrationConnection {
  id String @id @default(cuid())

  platform    IntegrationPlatform
  name        String
  apiKey      String?
  apiSecret   String?
  accessToken String?
  refreshToken String?
  shopUrl     String?
  isActive    Boolean @default(true)
  lastSyncAt  DateTime?
  config      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform])
}

enum IntegrationPlatform {
  KATANA
  REVERB
  SHOPIFY
  SHIPSTATION
  MANAGEMARKETS
  SHOPFLOW
}

// ============================================
// INVENTORY & SKU MAPPING
// ============================================

model InventoryItem {
  id String @id @default(cuid())

  sku           String   @unique
  name          String
  description   String?
  category      ItemCategory @default(FINISHED_GOOD)
  
  katanaQty     Int      @default(0)
  reverbQty     Int      @default(0)
  shopifyQty    Int      @default(0)
  shopflowQty   Int      @default(0)
  
  averageCost   Float?
  landedCost    Float?
  retailPrice   Float?
  
  leadTimeDays  Int?
  isReadyToShip Boolean  @default(false)
  
  lastKatanaSyncAt  DateTime?
  lastReverbSyncAt  DateTime?
  lastShopifySyncAt DateTime?

  skuMappings   SKUMapping[]
  syncLogs      SyncLog[]
  consumptions  ProductionConsumption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isReadyToShip])
}

enum ItemCategory {
  FINISHED_GOOD
  RAW_MATERIAL
  COMPONENT
  WORK_IN_PROGRESS
}

model SKUMapping {
  id String @id @default(cuid())

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  platform      IntegrationPlatform
  externalSku   String
  externalId    String?
  externalName  String?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, externalSku])
  @@index([inventoryItemId])
  @@index([platform])
}

// ============================================
// SYNC LOGS & ALERTS
// ============================================

model SyncLog {
  id String @id @default(cuid())

  syncType      SyncType
  platform      IntegrationPlatform
  status        SyncStatus
  direction     SyncDirection
  
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  
  previousValue Json?
  newValue      Json?
  errorMessage  String?
  details       String? @db.Text

  // True when this entry was produced by a dry run (no real write happened).
  dryRun        Boolean @default(false)

  resolvedAt    DateTime?
  resolvedBy    String?

  createdAt DateTime @default(now())

  @@index([syncType])
  @@index([platform])
  @@index([status])
  @@index([createdAt])
  @@index([inventoryItemId])
}

enum SyncType {
  INVENTORY_QUANTITY
  INVENTORY_COST
  PRODUCTION_CONSUMPTION
  ORDER_SYNC
  SKU_MAPPING
  LISTING_UPDATE
}

enum SyncStatus {
  SUCCESS
  FAILED
  PENDING
  PARTIAL
  SKIPPED
}

enum SyncDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

model Alert {
  id String @id @default(cuid())

  type        AlertType
  severity    AlertSeverity
  title       String
  message     String @db.Text
  
  relatedSku  String?
  relatedPlatform IntegrationPlatform?
  
  isRead      Boolean @default(false)
  isDismissed Boolean @default(false)
  
  actionUrl   String?
  actionLabel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([severity])
  @@index([isRead])
  @@index([createdAt])
}

enum AlertType {
  SYNC_FAILURE
  LOW_STOCK
  QUANTITY_MISMATCH
  CONNECTION_ERROR
  MANUAL_OVERRIDE
  COST_DISCREPANCY
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// ============================================
// PRODUCTION & CONSUMPTION
// ============================================

model ProductionOrder {
  id String @id @default(cuid())

  orderNumber   String   @unique
  productName   String
  productSku    String
  quantity      Int
  status        ProductionStatus @default(PLANNED)
  
  startedAt     DateTime?
  completedAt   DateTime?
  
  katanaWorkOrderId String?
  shopflowOrderId   String?

  consumptions  ProductionConsumption[]
  timers        ProductionTimer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([productSku])
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

model ProductionConsumption {
  id String @id @default(cuid())

  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantityConsumed Int
  unitCost         Float?
  
  consumedAt       DateTime @default(now())
  syncedToKatana   Boolean @default(false)
  katanaSyncAt     DateTime?

  @@index([productionOrderId])
  @@index([inventoryItemId])
  @@index([consumedAt])
}

model ProductionTimer {
  id String @id @default(cuid())

  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  stepName      String
  operatorName  String?
  
  startedAt     DateTime
  stoppedAt     DateTime?
  durationSecs  Int?
  
  laborCost     Float?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productionOrderId])
  @@index([startedAt])
}

// ============================================
// SHIPPING OPTIONS
// ============================================

model ShippingCarrier {
  id String @id @default(cuid())

  name        String
  code        String @unique
  platform    IntegrationPlatform
  isActive    Boolean @default(true)
  
  isDomestic     Boolean @default(true)
  isInternational Boolean @default(false)
  
  services    ShippingService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingService {
  id String @id @default(cuid())

  carrierId   String
  carrier     ShippingCarrier @relation(fields: [carrierId], references: [id], onDelete: Cascade)

  name        String
  code        String
  isActive    Boolean @default(true)
  
  estimatedDaysMin Int?
  estimatedDaysMax Int?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([carrierId, code])
  @@index([carrierId])
}

// ============================================
// SYNC CONFIGURATION
// ============================================

model SyncConfiguration {
  id String @id @default(cuid())

  syncType      SyncType
  isEnabled     Boolean @default(true)
  
  frequencyMins Int @default(15)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  
  config        Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([syncType])
}

// ============================================
// PROCESSED REVERB ORDERS (idempotency guard)
// ============================================

model ProcessedReverbOrder {
  id String @id @default(cuid())

  orderNumber   String   @unique
  source        String   @default("webhook")
  status        String?
  decrementApplied Boolean @default(false)
  katanaReference  String?

  payload       Json?
  processedAt   DateTime @default(now())

  @@index([processedAt])
}

// ============================================
// CATALOG STAGING (imported for SKU matching)
// ============================================

model KatanaCatalogVariant {
  id String @id @default(cuid())

  variantId    String  @unique
  productId    String?
  productName  String
  variantName  String?
  sku          String?
  isSellable   Boolean @default(true)

  lastImportedAt DateTime @default(now())

  @@index([sku])
}

model ReverbCatalogListing {
  id String @id @default(cuid())

  listingId    String  @unique
  title        String
  make         String?
  model        String?
  finish       String?
  state        String?
  inventory    Int?
  sku          String?
  // Reverb "unique" (one-of-a-kind) listings have has_inventory = false. We
  // ignore these for sync/mapping. Null = unknown (re-import to populate).
  hasInventory Boolean?

  lastImportedAt DateTime @default(now())

  @@index([state])
}
