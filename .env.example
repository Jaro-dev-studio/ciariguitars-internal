# Database (local Postgres via Docker Compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/internal_tools"

# NextAuth
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin impersonation password (optional)
ADMIN_PASS=""

# OpenAI (for AI Chat, optional)
OPENAI_API_KEY=""

# Anthropic (for AI Chat, optional)
ANTHROPIC_API_KEY=""

# Slack Integration (optional)
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""

# Katana MRP (Part 1 + Part 2)
KATANA_API_KEY=""
KATANA_API_BASE_URL="https://api.katanamrp.com/v1"
KATANA_WEBHOOK_TOKEN=""
KATANA_DEFAULT_LOCATION_ID=""
# Base URL of the Katana web app, used to build deep links from the SKU mapping UI.
# Exposed to the browser; adjust if your Katana app lives on a different host.
NEXT_PUBLIC_KATANA_APP_BASE_URL="https://factory.katanamrp.com"

# Cron / webhook shared secret
CRON_SECRET=""

# Reverb (Part 1)
REVERB_PERSONAL_ACCESS_TOKEN=""
REVERB_API_BASE_URL="https://api.reverb.com/api"
REVERB_USE_SANDBOX="false"

# Feature flags - keep writes off until verified end-to-end
SYNC_REVERB_WRITES_ENABLED="false"
SYNC_KATANA_WRITES_ENABLED="false"
SYNC_SHOPFLOW_WRITES_ENABLED="false"

# Shop Flow (Part 2 - pending GitSuite endpoints)
SHOPFLOW_API_KEY=""
SHOPFLOW_API_BASE_URL=""
SHOPFLOW_WEBHOOK_SECRET=""

